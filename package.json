{
  "name": "habitica-mcp-server",
  "version": "0.0.6",
  "description": "Model Context Protocol server for Habitica API integration. Enable AI assistants to manage your Habitica tasks, habits, pets, and rewards through natural language.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "habitica-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "start": "bun run dist/index.js",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "publish-check": "bun run scripts/publish-check.js",
    "prepublishOnly": "bun run build && bun run publish-check"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "mcp",
    "habitica",
    "productivity",
    "habits",
    "ai",
    "task-management",
    "rpg",
    "model-context-protocol",
    "claude",
    "assistant",
    "automation",
    "gamification"
  ],
  "author": {
    "name": "Breaker",
    "email": "breakerr@qq.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/mikedfunk/habitica-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikedfunk/habitica-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mikedfunk/habitica-mcp-server/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "FEATURES.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
